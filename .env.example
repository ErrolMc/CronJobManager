# Frontend (Next.js) environment variables.
# Copy this file to .env.local and fill in the values from your Supabase project
# dashboard (Settings -> API). .env.local is gitignored.

# Supabase project URL. Safe to expose in the browser; prefixed with NEXT_PUBLIC_
# so Next.js inlines it into client bundles when needed.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key. Safe to expose; RLS policies are what actually
# protect your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key. SERVER-ONLY. Bypasses RLS. Never expose this to
# the browser and never commit it. Used by API routes that need privileged access.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
